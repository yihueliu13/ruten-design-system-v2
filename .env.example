# ruten-design-system-v2 環境變數範例
#
# 複製本檔為 .env，填入實際值
# 注意：.env 必須加入 .gitignore，不可推上 git

# === 基本設定 ===
# NODE_ENV=development

# === API Keys（敏感，絕對不可進 git）===
# FIGMA_TOKEN=              # 從 Figma 拉 Variables（Phase 2 Tokens Studio 需要）
# GITHUB_TOKEN=             # 自動推 PR 到 Vue / RN repo

# === 第三方服務 ===
# CHROMATIC_PROJECT_TOKEN=  # Phase 2 視覺 regression
# NPM_TOKEN=                # 發布 @ruten/design-tokens 到 private registry
